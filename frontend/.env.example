# Authentication Configuration

# SSO Provider URL - opens in popup for authentication
# For local development with mock SSO:
VITE_AUTH_PROVIDER_URL=http://localhost:6001/sso

# For production SSO (SAML, OAuth, etc.):
# VITE_AUTH_PROVIDER_URL=https://your-sso-provider.com/auth

# localStorage key for auth credentials (must match backend AIB_AUTH_STORAGE_KEY)
VITE_AUTH_STORAGE_KEY=Auth

# Use inline iframe modal instead of new browser window (only if SSO provider allows framing)
# VITE_AUTH_USE_IFRAME=false

# postMessage targetOrigin (optional - defaults to provider URL origin)
# Use "*" only if you cannot restrict to a single origin
# VITE_AUTH_POST_MESSAGE_TARGET=https://your-sso-provider.com

# Popup polling interval (ms)
# VITE_AUTH_POLL_INTERVAL_MS=500

# Popup timeout (ms)
# VITE_AUTH_POPUP_TIMEOUT_MS=300000

# Preview/export path segments (must match backend flow44.paths constants)
VITE_PREVIEW_API_PREFIX=/api/preview
VITE_PREVIEW_PROXY_SEGMENT=proxy
VITE_EXPORT_API_PREFIX=/api/export
VITE_EXPORT_PUBLISHED_SEGMENT=published
