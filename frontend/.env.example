# --- External auth (SAML / postMessage popup) ---
# SSO opens in a popup only after the user clicks "Continue to sign in" (browser blocks auto popups).
# Full URL opened in the login popup (required unless session already exists or mock is on).
# VITE_AUTH_PROVIDER_URL=https://your-host/my/route/saml
# Dev-only static mock page (same Vite origin): /mock-auth.html — optional ?token=…&userId=…&userName=…
# VITE_AUTH_PROVIDER_URL=http://localhost:5173/mock-auth.html

# localStorage key for the JSON session blob (default: Auth). Must match backend AIB_AUTH_STORAGE_KEY.
# VITE_AUTH_STORAGE_KEY=Auth

# postMessage targetOrigin when polling the popup (default: origin of provider URL)
# VITE_AUTH_POST_MESSAGE_TARGET=https://your-host

# VITE_AUTH_POLL_INTERVAL_MS=500
# VITE_AUTH_POPUP_TIMEOUT_MS=300000

# Redirect when re-auth fails after 401 (default: /)
# VITE_AUTH_LOGIN_FALLBACK_URL=/

# --- Local / E2E: skip popup and store mock credentials ---
VITE_AUTH_MOCK=true
# VITE_AUTH_MOCK_TOKEN=mock-auth-token
# VITE_AUTH_MOCK_USER_ID=mock-user
# VITE_AUTH_MOCK_USER_NAME=Mock User
