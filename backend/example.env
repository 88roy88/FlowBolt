
# Database Configuration (PostgreSQL)
# Matches docker-compose postgres service
AIB_DB_SCHEME=postgresql
AIB_DB_NAME=flowbolt
AIB_DB_USER=postgres
AIB_DB_PASSWORD=postgres
AIB_DB_HOST=localhost
AIB_DB_PORT=5432

# Database Connection Pool Settings
AIB_DB_POOL_SIZE=5
AIB_DB_MAX_OVERFLOW=10
AIB_DB_POOL_RECYCLE=3600
AIB_DB_POOL_PRE_PING=true

# AI Model Configuration
# Default: self-hosted vLLM with Qwen Coder
AIB_AI_MODEL=qwen/qwen3-coder-30b-a3b-instruct
AIB_AI_BASE_URL=http://ai-builder-models.com/openai/v1
AIB_AI_API_KEY=default

# For OpenRouter:
# AIB_AI_MODEL=minimax/minimax-m2.5
# AIB_AI_BASE_URL=https://openrouter.ai/api/v1
# AIB_AI_API_KEY=sk-or-v1-...

# For Ollama:
# AIB_AI_MODEL=qwen3:30b
# AIB_AI_BASE_URL=http://localhost:11434/v1
# AIB_AI_API_KEY=default

# For Anthropic API (direct, uses ANTHROPIC_API_KEY env var):
# AIB_AI_MODEL=anthropic:claude-sonnet-4-5-20250514

# For AWS Bedrock (uses native provider, AI_BASE_URL ignored):
# AIB_AI_MODEL=bedrock:us.anthropic.claude-sonnet-4-6

# Langfuse (optional — for observability/tracing)
# AIB_LANGFUSE_PUBLIC_KEY=pk-lf-...
# AIB_LANGFUSE_SECRET_KEY=sk-lf-...
# AIB_LANGFUSE_HOST=https://cloud.langfuse.com
