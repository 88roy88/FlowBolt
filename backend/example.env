
# Database (SQLite default or PostgreSQL)
# For local dev: postgresql://postgres:postgres@localhost:5432/flowbolt
AIB_DATABASE_URL="sqlite:///./ai_builder.db"
AIB_DB_POOL_SIZE=5
AIB_DB_MAX_OVERFLOW=10
AIB_DB_POOL_RECYCLE=3600
AIB_DB_POOL_PRE_PING=true

# OpenRouter API Key and Model
AIB_AI_MODEL="openrouter/minimax/minimax-m2.5"
OPENROUTER_API_KEY="sk-or-v1-..."

# Langfuse (optional — for observability/tracing)
# AIB_LANGFUSE_PUBLIC_KEY="pk-lf-..."
# AIB_LANGFUSE_SECRET_KEY="sk-lf-..."
# AIB_LANGFUSE_HOST="https://cloud.langfuse.com"

# S3 / Object Storage (Defaults for local MinIO)
S3_ENDPOINT_URL="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET_NAME="flowbolt"
S3_CACHE_TTL=3600