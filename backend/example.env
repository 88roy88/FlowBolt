
# Database Configuration (PostgreSQL)
# Matches docker-compose postgres service
AIB_DB_SCHEME=postgresql
AIB_DB_NAME=flow44
AIB_DB_USER=postgres
AIB_DB_PASSWORD=postgres
AIB_DB_HOST=localhost
AIB_DB_PORT=5432

# For SQLite (Alternative)
# To use SQLite, comment out the PostgreSQL settings above and uncomment these:
# AIB_DB_SCHEME=sqlite
# AIB_DB_NAME=ai_builder.db

# Database Connection Pool Settings
AIB_DB_POOL_SIZE=5
AIB_DB_MAX_OVERFLOW=10
AIB_DB_POOL_RECYCLE=3600
AIB_DB_POOL_PRE_PING=true

# AI Model Configuration
# Default: self-hosted vLLM with Qwen Coder
AIB_AI_MODEL=qwen/qwen3-coder-30b-a3b-instruct
AIB_AI_BASE_URL=http://flow-44-models.com/openai/v1
AIB_AI_API_KEY=default

# For OpenRouter:
# AIB_AI_MODEL=minimax/minimax-m2.5
# AIB_AI_BASE_URL=https://openrouter.ai/api/v1
# AIB_AI_API_KEY=sk-or-v1-...

# For Ollama:
# AIB_AI_MODEL=qwen3:30b
# AIB_AI_BASE_URL=http://localhost:11434/v1
# AIB_AI_API_KEY=default

# For Anthropic API (direct, uses ANTHROPIC_API_KEY env var):
# AIB_AI_MODEL=anthropic:claude-sonnet-4-5-20250514

# For AWS Bedrock (uses native provider, AI_BASE_URL ignored):
# AIB_AI_MODEL=bedrock:us.anthropic.claude-sonnet-4-6

# Langfuse (optional — for observability/tracing)
# AIB_LANGFUSE_PUBLIC_KEY=pk-lf-...
# AIB_LANGFUSE_SECRET_KEY=sk-lf-...
# AIB_LANGFUSE_HOST=https://cloud.langfuse.com

# Authentication / JWT Validation
# Dev RSA public key — matches the private key embedded in mocks/flapi-mock/server.js.
# Copy the block below (including the quotes) into your .env to enable JWT signature verification.
# AIB_AUTH_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
# MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA5rlPsrOc6JVYs6jqDizj
# xDOqisNTts7yw66deyze9Hz3CC5aixvPrnAiRvOU75cR6PQYzXtPMCsZflfmILgJ
# BfPAlRc7yF211JBY6u9Iq6K3JN7cNyhH79GW6dDMZyqINXMea84eQmBwbQKHgqwF
# QF+hBtIGfVKAapRiBbQAEcYFFVFjQ2rH4cyAiPLwHotKHP+Aa9/9E1Le3m60pNFA
# Z1iJ/7ovLm1o0ENTQKbFEyzXbupet2fzkUn8jauPVDOpWxFxsEI47dVlb5JZULnu
# szX30m3EQD5lDjbNDMUVmo23eriQjDhamhr7Rbh26N8Di6WkZv6GnzsbpPmdprp2
# TwIDAQAB
# -----END PUBLIC KEY-----"

# JWT algorithm (RS256 for RSA — default, matches the mock)
# AIB_AUTH_JWT_ALGORITHM=RS256

# Require JWT format (reject opaque tokens)
# AIB_AUTH_REQUIRE_JWT=false

# SSO auth for generated apps (injected into vite.config.ts at scaffold time)
# AIB_SANDBOX_AUTH_PROVIDER_URL=http://localhost:6001/sso
# AIB_SANDBOX_AUTH_STORAGE_KEY=Auth
# AIB_SANDBOX_AUTH_USE_IFRAME=true

# Flapi upstream (data-source search / run)
# Raw SSO tokens from browser are automatically sent to FLAPI as "Bearer <token>"
# AIB_FLAPI_BASE_URL=http://localhost:6001
# AIB_FLAPI_VERIFY_SSL=true

# --- Build & Dependency Configuration ---

# NPM / PNPM Configuration
# These are used by .npmrc in the backend and pnpm-project-template
NPM_REGISTRY=https://registry.npmjs.org/
NPM_STRICT_SSL=true
NPM_AUDIT=true

# UV (Python) Configuration
# These are used during the Docker build (App.Dockerfile) to generate uv.toml
BACKEND_BASE_IMAGE=python:3.12-slim
UV_INDEX_URL=https://pypi.org/simple
UV_NATIVE_TLS=true
UV_INDEX_NAME=default
UV_INDEX_DEFAULT=true
UV_INSECURE_HOST1=
UV_INSECURE_HOST2=

# --- Frontend Build & Runtime Configuration ---
# Used as --build-arg in frontend/Dockerfile
FRONTEND_BASE_IMAGE=node:20-slim
NGINX_IMAGE=nginx:alpine

# The internal address of the backend service (used as reference for nginx.conf)
BACKEND_INTERNAL_URL=http://base-backend.base:8000
