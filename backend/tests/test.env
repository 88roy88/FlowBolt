# Test Environment Configuration
AIB_DB_SCHEME=sqlite
AIB_DB_NAME=:memory:
AIB_DB_USER=test_user
AIB_DB_PASSWORD=test_pass
AIB_DB_HOST=localhost
AIB_DB_PORT=5432
AIB_MAX_COMMAND_TIMEOUT=30
# Dummy secret — every test patches flow44.api.auth.settings, so this value
# only needs to satisfy the required-field check at import time.
AIB_AUTH_JWT_PUBLIC_KEY=test-public-key-not-used
